ANTHROPIC_API_KEY=your_api_key_here
PORT=3000

# Vercel Blob (auto-added when you connect a Blob store to your project)
# Uses BLOB_STORE_ID + VERCEL_OIDC_TOKEN, or the legacy BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Secret used to download the email list as CSV
EXPORT_SECRET=choose_a_long_random_secret
